{
  "name": "nextswimmingschoolv2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "dotenv -e .env.test -- playwright test",
    "test:e2e:public": "dotenv -e .env.test -- playwright test --project=public --project=public-mobile",
    "test:e2e:ui": "dotenv -e .env.test -- playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:headed": "dotenv -e .env.test -- playwright test --headed",
    "test:e2e:flow": "dotenv -e .env.test -- playwright test --project=flow-owner --project=flow-admin --project=flow-coach --project=flow-member",
    "test:e2e:flow:owner": "dotenv -e .env.test -- playwright test --project=flow-owner",
    "test:e2e:flow:admin": "dotenv -e .env.test -- playwright test --project=flow-admin",
    "test:e2e:flow:coach": "dotenv -e .env.test -- playwright test --project=flow-coach",
    "test:e2e:flow:member": "dotenv -e .env.test -- playwright test --project=flow-member"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@sentry/nextjs": "^10.57.0",
    "@sparticuz/chromium-min": "^149.0.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@types/leaflet": "^1.9.21",
    "@types/qrcode": "^1.5.6",
    "gsap": "^3.15.0",
    "html5-qrcode": "^2.3.8",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "next": "16.2.6",
    "puppeteer-core": "^25.3.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.1.8",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "shadcn": "^4.13.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
